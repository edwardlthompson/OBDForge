    <string name="welcome_title">Welcome to OBDForge</string>
    <string name="welcome_intro">OBDForge runs entirely on your phone. These Android permissions let the app talk to OBD adapters, scan VIN barcodes, and optionally check for updates. Nothing is sent to a remote analytics service.</string>
    <string name="welcome_continue">Continue to app</string>
