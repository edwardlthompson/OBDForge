    <string name="welcome_permission_bluetooth_title">Bluetooth</string>
    <string name="welcome_permission_bluetooth_body">Connect to wireless OBD-II adapters (Classic SPP and BLE). Required on Android 12 and newer; older versions grant this at install time.</string>
    <string name="welcome_permission_camera_title">Camera</string>
    <string name="welcome_permission_camera_body">Scan the VIN barcode on the door jamb or registration document. The camera is used only when you open the VIN scanner.</string>
    <string name="welcome_permission_network_title">Network</string>
    <string name="welcome_permission_network_body">Optional release update checks and loading donation links in About. Granted automatically at install — no runtime prompt.</string>
    <string name="welcome_permission_usb_title">USB serial adapter</string>
    <string name="welcome_permission_usb_body">Wired ELM327 and STN adapters use Android\'s per-device USB prompt. Plug in your adapter, then tap Grant for each device listed below.</string>
